<?xml version="1.0" encoding="utf-8"?>
<!-- res/drawable/bg_card_glass.xml -->
<!--
    Simulasi efek glassmorphism dari Figma:
    - Overlay+Blur layer → warna 004371 opacity 5%
    - Fill linear: FFFFFF 100% → transparan
    - Stroke tipis biru muda
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Layer 1: Gradient putih ke biru transparan (glass fill) -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#EAFAFF"
                android:endColor="#99D6EEFF" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <!-- Layer 2: Overlay blur simulasi (004371 @ 5%) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0D004371" />
            <corners android:radius="24dp" />
            <stroke
                android:width="1dp"
                android:color="#3377BBFD" />
        </shape>
    </item>

</layer-list>
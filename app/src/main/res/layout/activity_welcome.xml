<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A1D2D"
    tools:context="activity.WelcomeActivity">

    <!-- BACKGROUND IMAGE — rename foto Pinterest jadi img_welcome_bg, taruh di res/drawable/ -->
    <ImageView
        android:id="@+id/imgBackground"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_welcom"
        android:contentDescription="Background"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Overlay gelap gradient di atas foto -->

    <!-- =============================================
         TOP SECTION — Logo + Headline + Deskripsi (semua CENTER)
         ============================================= -->

    <!-- Logo: Icon kiri + teks "Kabarin", posisi center horizontal -->

    <View
        android:id="@+id/viewOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_welcome_overlay"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0" />

    <LinearLayout
        android:id="@+id/layoutBrandAnchor"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="56dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

    </LinearLayout>

    <!-- Headline — center -->

    <!-- Deskripsi — center -->

    <!-- =============================================
         BOTTOM CARD — Get Started + Categories
         ============================================= -->

    <TextView
        android:id="@+id/tvHeadline"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="104dp"
        android:layout_marginEnd="24dp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:text="Stay Updated, Stay Informed"
        android:textColor="#FFFFFF"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutBrandAnchor" />

    <TextView
        android:id="@+id/tvDescription"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="32dp"
        android:fontFamily="sans-serif"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:text="Experience journalism redefined. Jakarta\'s most trusted premium news ecosystem, delivered with clarity and intelligence."
        android:textColor="#CCF7F9FF"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvHeadline" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardBottomSheet"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="32dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="16dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="32dp"
            android:paddingBottom="40dp">

            <!-- Tombol Get Started -->
            <Button
                android:id="@+id/btnGetStarted"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Get Started"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:backgroundTint="#004371"
                android:stateListAnimator="@null"
                app:cornerRadius="14dp" />

            <!-- Label Explore Categories -->
            <TextView
                android:id="@+id/tvExploreLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="EXPLORE CATEGORIES"
                android:textColor="#99727780"
                android:textSize="10sp"
                android:letterSpacing="0.14"
                android:fontFamily="sans-serif" />

            <!-- Chip Categories -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupCategories"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:singleLine="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipPolitics"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Politics"
                    android:textColor="#004371"
                    android:textSize="12sp"
                    app:chipBackgroundColor="#3377BBFD"
                    app:chipStrokeColor="#7777BBFD"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="100dp"
                    app:rippleColor="#3377BBFD" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipBusiness"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Business"
                    android:textColor="#004371"
                    android:textSize="12sp"
                    app:chipBackgroundColor="#3377BBFD"
                    app:chipStrokeColor="#7777BBFD"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="100dp"
                    app:rippleColor="#3377BBFD" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipTech"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tech"
                    android:textColor="#004371"
                    android:textSize="12sp"
                    app:chipBackgroundColor="#3377BBFD"
                    app:chipStrokeColor="#7777BBFD"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="100dp"
                    app:rippleColor="#3377BBFD" />

            </com.google.android.material.chip.ChipGroup>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <ImageView
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:contentDescription="Kabarin Icon"
        android:src="@drawable/ic_kabarin_logo"
        app:tint="#FFFFFF"
        tools:layout_editor_absoluteX="155dp"
        tools:layout_editor_absoluteY="98dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-medium"
        android:text="Kabarin"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        tools:layout_editor_absoluteX="183dp"
        tools:layout_editor_absoluteY="98dp" />

</androidx.constraintlayout.widget.ConstraintLayout>